# ClearHeat backend environment variables
# Copy this file to .env and fill in your values

# Supabase Postgres connection string
# Find this in: Supabase dashboard → Project Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# Resend API key for installer email notifications
# Get this from: https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# Email address of the Dublin installer to notify on new leads
INSTALLER_EMAIL=installer@example.com

# The from address for ClearHeat emails (must be a verified domain in Resend)
CLEARHEAT_FROM_EMAIL=noreply@clearheat.ie

# Google Business Profile review link
# Get this from: Google Business Profile dashboard → Ask for reviews → Get more reviews
# Leave blank until you have a verified Google Business Profile for ClearHeat
GOOGLE_REVIEW_URL=

# Internal PDF endpoint key (optional — legacy use only)
CLEARHEAT_PDF_KEY=
